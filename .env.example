# Discord Bot Token (from Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=your_discord_bot_token_here

# SMTP Settings (for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Single-account fallback (required for OTP delivery)
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Optional: Multiple accounts for load balancing (comma-separated, same count for both)
# SMTP_EMAILS=account1@gmail.com,account2@gmail.com
# SMTP_PASSWORDS=app_password_1,app_password_2

# Optional: For migration script - specific guild ID (default: first guild)
# DISCORD_GUILD_ID=123456789012345678
