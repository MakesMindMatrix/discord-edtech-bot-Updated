# Environment variables
.env

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
.venv/

# Logs
logs/*
!logs/.gitkeep

# Database and CSV — user uploads manually
*.db
*.sqlite3
*.csv

# data/ folder — ignore contents, keep .gitkeep for structure
data/*
!data/.gitkeep

# VS Code
.vscode/

# IDE
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Distribution
dist/
build/
*.egg-info/
